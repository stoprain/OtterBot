# GitHub token with Copilot access
# Get one at: https://github.com/settings/tokens
# Required scopes: copilot (or use a fine-grained token with Copilot Chat enabled)
GITHUB_TOKEN=your_github_token_here

# Optional: override the model (default: gpt-4o)
# COPILOT_MODEL=gpt-4o

# Optional: max tokens for completions (default: 4096)
# MAX_TOKENS=4096
